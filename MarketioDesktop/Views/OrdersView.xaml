<UserControl x:Class="Marketio_WPF.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Marketio_WPF.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1100"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">

            <TextBlock Text="📋 Orders"
                       Style="{StaticResource ViewHeaderStyle}"/>

            <Button Content="🔄 Refresh"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="20,0,0,0"/>
        </StackPanel>

        <!-- Berichten -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">

            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource ErrorMessageStyle}"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <TextBlock Text="{Binding SuccessMessage}"
                       Style="{StaticResource SuccessMessageStyle}"
                       Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>

        <!-- Filter bar -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">

            <TextBlock Text="Filter op status:"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Margin="0,0,8,0"/>

            <ComboBox x:Name="StatusFilterBox"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding StatusFilter, Mode=TwoWay}"
                      Width="140"
                      Height="28"
                      Margin="0,0,8,0">

                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="Pending"/>
                <ComboBoxItem Content="Processing"/>
                <ComboBoxItem Content="Shipped"/>
                <ComboBoxItem Content="Delivered"/>
                <ComboBoxItem Content="Cancelled"/>

            </ComboBox>

            <Button Content="▶ Filter"
                    Command="{Binding FilterByStatusCommand}"
                    Style="{StaticResource NeutralButtonStyle}"
                    Padding="10,4"/>
        </StackPanel>

        <!-- Orders DataGrid -->
        <DataGrid Grid.Row="3"
                  Style="{StaticResource StandardDataGridStyle}"
                  ItemsSource="{Binding Orders}"
                  SelectedItem="{Binding SelectedOrder, Mode=TwoWay}">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="45"/>

                <DataGridTextColumn Header="Order #"
                                    Binding="{Binding OrderNumber}"
                                    Width="130"/>

                <DataGridTextColumn Header="Klant-ID"
                                    Binding="{Binding CustomerId}"
                                    Width="160"/>

                <DataGridTextColumn Header="Datum"
                                    Binding="{Binding OrderDate, StringFormat={}{0:dd/MM/yyyy}}"
                                    Width="90"/>

                <DataGridTemplateColumn Header="Status" Width="115" SortMemberPath="StatusName">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <controls:StatusBadge Status="{Binding StatusName}"
                                                  Margin="2,1"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Betaling"
                                    Binding="{Binding PaymentMethodName}"
                                    Width="105"/>

                <DataGridTextColumn Header="Totaal"
                                    Binding="{Binding TotalAmount, StringFormat=€{0:N2}}"
                                    Width="80"/>

                <DataGridCheckBoxColumn Header="Actief"
                                        Binding="{Binding IsActive}"
                                        Width="55"/>

                <DataGridTextColumn Header="Verzendadres"
                                    Binding="{Binding ShippingAddress}"
                                    Width="*"/>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom toolbar -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Right">

            <Button Content="➕ Nieuwe order"
                    Command="{Binding CreateOrderCommand}"
                    Style="{StaticResource SuccessButtonStyle}"
                    Margin="0,0,5,0"/>

            <Button Content="✏️ Update Status"
                    Command="{Binding UpdateOrderCommand}"
                    Style="{StaticResource WarningButtonStyle}"
                    Margin="0,0,5,0"/>

            <Button Content="🗑️ Delete"
                    Command="{Binding DeleteOrderCommand}"
                    Style="{StaticResource DangerButtonStyle}"/>

        </StackPanel>

        <!-- Loading -->
        <ProgressBar Grid.Row="3"
                     Height="4"
                     VerticalAlignment="Top"
                     IsIndeterminate="True"
                     Visibility="{Binding IsBusy,
                         Converter={StaticResource BoolToVisibilityConverter}}"/>

    </Grid>
</UserControl>