<UserControl x:Class="Marketio_WPF.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Background="#F5F5F5"
        Foreground="#333333">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Border Background="White"
                CornerRadius="12"
                Padding="25"
                Margin="20">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Title -->
                    <TextBlock Text="📝 Create Account"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#2C3E50"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,25"/>

                    <!-- Email -->
                    <TextBlock Text="Email"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Height="40"
                             Padding="10"
                             FontSize="12"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1"
                             Margin="0,0,0,15"/>

                    <!-- Voornaam -->
                    <TextBlock Text="First Name"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                             Height="40"
                             Padding="10"
                             FontSize="12"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1"
                             Margin="0,0,0,15"/>

                    <!-- Achternaam -->
                    <TextBlock Text="Last Name"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                             Height="40"
                             Padding="10"
                             FontSize="12"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1"
                             Margin="0,0,0,15"/>

                    <!-- Wachtwoord -->
                    <TextBlock Text="Password"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <PasswordBox x:Name="PasswordBox"
                                 Height="40"
                                 Padding="10"
                                 FontSize="12"
                                 BorderBrush="#BDC3C7"
                                 BorderThickness="1"
                                 Margin="0,0,0,15"/>

                    <!-- Confirm Wachtwoord -->
                    <TextBlock Text="Confirm Password"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Height="40"
                                 Padding="10"
                                 FontSize="12"
                                 BorderBrush="#BDC3C7"
                                 BorderThickness="1"
                                 Margin="0,0,0,20"/>

                    <!-- Terms -->
                    <CheckBox Content="I accept the Terms of Service"
                              IsChecked="{Binding AcceptTerms}"
                              FontSize="11"
                              Margin="0,0,0,10"/>

                    <!-- Privacy -->
                    <CheckBox Content="I accept the Privacy Policy"
                              IsChecked="{Binding AcceptPrivacyPolicy}"
                              FontSize="11"
                              Margin="0,0,0,20"/>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource ErrorMessageStyle}"
                               Margin="0,0,0,15"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Register Button -->
                    <Button Content="✓ Create Account"
                            Command="{Binding RegisterCommand}"
                            Style="{StaticResource SuccessButtonStyle}"
                            Height="45"
                            FontSize="14"
                            Margin="0,0,0,10"/>

                    <!-- Back Button -->
                    <Button Content="← Back to Login"
                            Style="{StaticResource NeutralButtonStyle}"
                            Height="40"
                            FontSize="12"
                            Click="BackToLogin_Click"/>

                    <!-- Loading -->
                    <ProgressBar IsIndeterminate="True"
                                 Height="5"
                                 Margin="0,20,0,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>