<UserControl x:Class="Marketio_WPF.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1000"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <!-- WPF built-in converter: geen project-assembly nodig voor de XAML designer.
             Styles (PrimaryButtonStyle enz.) komen uit App.xaml — designer vindt die wél
             omdat styles alleen WPF built-in types gebruiken. -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ROW 0 – Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="⚙️ User Management"
                       Style="{StaticResource ViewHeaderStyle}"/>
            <Button Content="🔄 Refresh"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="20,0,0,0"/>
        </StackPanel>

        <!-- ROW 1 – Feedback messages -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource ErrorMessageStyle}"
                       Visibility="{Binding HasError,
                           Converter={StaticResource BoolToVisibilityConverter}}"/>
            <TextBlock Text="{Binding SuccessMessage}"
                       Style="{StaticResource SuccessMessageStyle}"
                       Visibility="{Binding HasSuccess,
                           Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>

        <!-- ROW 2 – User list (links)  +  Action panel (rechts) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- User DataGrid -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          Style="{StaticResource StandardDataGridStyle}"
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser, Mode=TwoWay}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Full Name"
                                            Binding="{Binding FullName}"
                                            Width="150"/>
                        <DataGridTextColumn Header="Email"
                                            Binding="{Binding Email}"
                                            Width="200"/>
                        <DataGridTextColumn Header="Username"
                                            Binding="{Binding UserName}"
                                            Width="120"/>
                        <DataGridTextColumn Header="Roles"
                                            Binding="{Binding Roles}"
                                            Width="100"/>
                        <DataGridCheckBoxColumn Header="Active"
                                                Binding="{Binding IsActive}"
                                                Width="55"/>
                        <DataGridCheckBoxColumn Header="Locked"
                                                Binding="{Binding IsLocked}"
                                                Width="55"/>
                        <DataGridTextColumn Header="Created"
                                            Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy\}}"
                                            Width="90"/>
                        <DataGridTextColumn Header="Last Login"
                                            Binding="{Binding LastLoginAt, StringFormat=\{0:dd/MM/yyyy\}}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <ProgressBar Grid.Row="1"
                             IsIndeterminate="True" Height="4"
                             Visibility="{Binding IsBusy,
                                 Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>

            <!-- Action Panel -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Selecteer gebruiker info kaart -->
                    <Border Background="#ECF0F1"
                            BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Selected user"
                                       FontSize="11" Foreground="#7F8C8D"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedUser.FullName, FallbackValue='— none —'}"
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="#2C3E50" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedUser.Email, FallbackValue=''}"
                                       FontSize="11" Foreground="#555"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedUser.Roles, StringFormat='Roles: {0}', FallbackValue=''}"
                                       FontSize="11" Foreground="#555"
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 1. Role Management -->
                    <Border Background="White"
                            BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="🎭 Role Management"
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="#2C3E50" Margin="0,0,0,8"/>

                            <TextBlock Text="Select role" FontSize="11"
                                       Foreground="#7F8C8D" Margin="0,0,0,3"/>
                            <ComboBox ItemsSource="{Binding AvailableRoles}"
                                      SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                      Height="28" Margin="0,0,0,8"/>

                            <Button Content="✅ Assign Role"
                                    Command="{Binding AssignRoleCommand}"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Margin="0,0,0,5" HorizontalAlignment="Stretch"/>

                            <!-- Remove Role: oranje variant zonder eigen stijl -->
                            <Button Content="❌ Remove Role"
                                    Command="{Binding RemoveRoleCommand}"
                                    Background="#E67E22"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <!-- 2. Account Status – Blokkeer / Deblokkeer -->
                    <Border Background="#EAF4FB"
                            BorderBrush="#2980B9" BorderThickness="1"
                            CornerRadius="4" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="🔒 Account Status"
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="#1A5276" Margin="0,0,0,4"/>
                            <TextBlock Text="Blokkeer permanent of deblokkeer de geselecteerde gebruiker."
                                       FontSize="10" Foreground="#999"
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <!-- Block: oranje — zelfde signaalniveau als Remove Role -->
                            <Button Content="🚫 Block User"
                                    Command="{Binding LockUserCommand}"
                                    Background="#E67E22" Foreground="White"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,5"/>

                            <!-- Unblock: groen — herstelt toegang -->
                            <Button Content="✅ Unblock User"
                                    Command="{Binding UnlockUserCommand}"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <!-- 3. GDPR – User Deletion -->
                    <Border Background="#FDF2F2"
                            BorderBrush="{StaticResource DangerBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10">
                        <StackPanel>
                            <TextBlock Text="🗑️ User Deletion"
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="#C0392B" Margin="0,0,0,4"/>
                            <TextBlock Text="Permanently removes account (GDPR Right to be Forgotten)."
                                       FontSize="10" Foreground="#999"
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>

                            <Button Content="🗑️ Delete User"
                                    Command="{Binding DeleteUserCommand}"
                                    Style="{StaticResource DangerButtonStyle}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>