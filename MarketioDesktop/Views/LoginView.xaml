<Window x:Class="Marketio_WPF.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Marketio Login"
        Height="500"
        Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Foreground="#333333">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">

            <!-- Logo / Titel -->
            <TextBlock Text="📊 Marketio"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       TextAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Administration Portal"
                       FontSize="14"
                       Foreground="#7F8C8D"
                       TextAlignment="Center"
                       Margin="0,0,0,30"/>

            <!-- Email Input -->
            <TextBlock Text="Email"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#2C3E50"
                       Margin="0,0,0,5"/>

            <TextBox x:Name="EmailTextBox"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     Padding="12"
                     FontSize="12"
                     Background="White"
                     BorderThickness="1"
                     BorderBrush="#BDC3C7"
                     Margin="0,0,0,15"/>

            <!-- Wachtwoord Input -->
            <TextBlock Text="Password"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#2C3E50"
                       Margin="0,0,0,5"/>

            <PasswordBox x:Name="PasswordBox"
                         Padding="12"
                         FontSize="12"
                         Background="White"
                         BorderThickness="1"
                         BorderBrush="#BDC3C7"
                         Margin="0,0,0,15"/>

            <!-- Remember Me Checkbox -->
            <CheckBox Content="Remember me"
                      IsChecked="{Binding RememberMe}"
                      FontSize="12"
                      Foreground="#7F8C8D"
                      Margin="0,0,0,20"/>

            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource ErrorMessageStyle}"
                       Margin="0,0,0,10"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Success Message -->
            <TextBlock Text="{Binding SuccessMessage}"
                       Style="{StaticResource SuccessMessageStyle}"
                       Margin="0,0,0,10"
                       Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Login Button -->
            <Button Content="🔓 Login"
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    FontSize="14"
                    Padding="12"
                    Margin="0,0,0,10"/>

            <!-- Register Button -->
            <Button Content="➕ Create Account"
                    Command="{Binding RegisterCommand}"
                    Style="{StaticResource NeutralButtonStyle}"
                    FontSize="14"
                    Padding="12"/>

            <!-- Loading Indicator -->
            <ProgressBar IsIndeterminate="True"
                         Height="4"
                         Background="#ECF0F1"
                         Foreground="#3498DB"
                         Margin="0,20,0,0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</Window>