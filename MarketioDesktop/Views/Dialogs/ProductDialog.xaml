<Window x:Class="Marketio_WPF.Views.Dialogs.ProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Marketio_WPF.Converters"
        SizeToContent="Height"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Border Background="White" CornerRadius="8" Margin="15" Padding="22">
        <StackPanel>

            <TextBlock x:Name="TitleText"
                       Text="➕ Nieuw product"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,0,0,20"/>

            <!-- Naam -->
            <TextBlock Text="Naam *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox" Height="34" Padding="8" FontSize="12"
                     BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,12"/>

            <!-- Description -->
            <TextBlock Text="Beschrijving *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="DescriptionBox" Height="72" Padding="8" FontSize="12"
                     BorderBrush="#BDC3C7" BorderThickness="1"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Margin="0,0,0,12"/>

            <!-- Prijs + Voorraad -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Prijs (€) *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="PriceBox" Height="34" Padding="8" FontSize="12"
                             BorderBrush="#BDC3C7" BorderThickness="1"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Voorraad *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="StockBox" Height="34" Padding="8" FontSize="12"
                             BorderBrush="#BDC3C7" BorderThickness="1"/>
                </StackPanel>
            </Grid>

            <!-- Categorie -->
            <TextBlock Text="Categorie *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox x:Name="CategoryBox" Height="34" Margin="0,0,0,12">
                <ComboBoxItem Content="Electronics"   Tag="1"/>
                <ComboBoxItem Content="Clothing"      Tag="2"/>
                <ComboBoxItem Content="Books"         Tag="3"/>
                <ComboBoxItem Content="HomeAndGarden" Tag="4"/>
                <ComboBoxItem Content="Sports"        Tag="5"/>
            </ComboBox>

            <!-- Image URL -->
            <TextBlock Text="Afbeelding-URL *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="ImageUrlBox" Height="34" Padding="8" FontSize="12"
                     BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,12"/>

            <!-- IsActive -->
            <CheckBox x:Name="IsActiveCheck" Content="Actief" IsChecked="True"
                      FontSize="12" Margin="0,0,0,16"/>

            <!-- Validation error -->
            <TextBlock x:Name="ErrorText"
                       Foreground="#E74C3C" FontSize="11"
                       TextWrapping="Wrap" Margin="0,0,0,12"
                       Visibility="Collapsed"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="✓ Opslaan"
                        Width="100" Height="36"
                        Background="#27AE60" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Margin="0,0,8,0" Click="Save_Click"/>
                <Button Content="✕ Annuleren"
                        Width="100" Height="36"
                        Background="#95A5A6" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>