<Window x:Class="Marketio_WPF.Views.Dialogs.CustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="Height"
        Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Border Background="White" CornerRadius="8" Margin="15" Padding="22">
        <StackPanel>

            <TextBlock x:Name="TitleText"
                       Text="➕ Nieuwe klant"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,0,0,20"/>

            <!-- Voornaam + Achternaam -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Voornaam *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="FirstNameBox" Height="34" Padding="8" FontSize="12"
                             BorderBrush="#BDC3C7" BorderThickness="1"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Achternaam *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="LastNameBox" Height="34" Padding="8" FontSize="12"
                             BorderBrush="#BDC3C7" BorderThickness="1"/>
                </StackPanel>
            </Grid>

            <!-- Email -->
            <TextBlock Text="Email *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="EmailBox" Height="34" Padding="8" FontSize="12"
                     BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,12"/>

            <!-- Phone -->
            <TextBlock Text="Telefoon *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="PhoneBox" Height="34" Padding="8" FontSize="12"
                     BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,12"/>

            <!-- Address -->
            <TextBlock Text="Adres *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="AddressBox" Height="60" Padding="8" FontSize="12"
                     BorderBrush="#BDC3C7" BorderThickness="1"
                     TextWrapping="Wrap" AcceptsReturn="False"
                     Margin="0,0,0,12"/>

            <!-- IsActive -->
            <CheckBox x:Name="IsActiveCheck" Content="Actief" IsChecked="True"
                      FontSize="12" Margin="0,0,0,16"/>

            <!-- Validation error -->
            <TextBlock x:Name="ErrorText"
                       Foreground="#E74C3C" FontSize="11"
                       TextWrapping="Wrap" Margin="0,0,0,12"
                       Visibility="Collapsed"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="✓ Opslaan"
                        Width="100" Height="36"
                        Background="#27AE60" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Margin="0,0,8,0" Click="Save_Click"/>
                <Button Content="✕ Annuleren"
                        Width="100" Height="36"
                        Background="#95A5A6" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>