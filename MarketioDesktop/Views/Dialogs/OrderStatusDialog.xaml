<Window x:Class="Marketio_WPF.Views.Dialogs.OrderStatusDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orderstatus bijwerken"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Border Background="White" CornerRadius="8" Margin="15" Padding="22">
        <StackPanel>

            <TextBlock Text="✏️ Orderstatus bijwerken"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,0,0,16"/>

            <!-- Read-only order summary -->
            <Border Background="#ECF0F1" CornerRadius="4"
                    Padding="10" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock x:Name="OrderNumberText" FontSize="12" Foreground="#555"/>
                    <TextBlock x:Name="OrderDateText"   FontSize="12" Foreground="#555" Margin="0,3,0,0"/>
                    <TextBlock x:Name="OrderTotalText"  FontSize="12" Foreground="#555" Margin="0,3,0,0"/>
                    <TextBlock x:Name="CurrentStatusText" FontSize="12" Foreground="#555" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <!-- Nieuwe status -->
            <TextBlock Text="Nieuwe status *"
                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox x:Name="StatusBox" Height="34" Margin="0,0,0,20">
                <ComboBoxItem Content="Pending"/>
                <ComboBoxItem Content="Processing"/>
                <ComboBoxItem Content="Shipped"/>
                <ComboBoxItem Content="Delivered"/>
                <ComboBoxItem Content="Cancelled"/>
            </ComboBox>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="✓ Opslaan"
                        Width="100" Height="36"
                        Background="#27AE60" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Margin="0,0,8,0" Click="Save_Click"/>
                <Button Content="✕ Annuleren"
                        Width="100" Height="36"
                        Background="#95A5A6" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>