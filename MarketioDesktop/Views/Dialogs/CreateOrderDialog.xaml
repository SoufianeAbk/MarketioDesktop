<Window x:Class="MarketioDesktop.Views.Dialogs.CreateOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nieuwe order aanmaken"
        Width="560"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Border Background="White" CornerRadius="8" Margin="15" Padding="22">
        <StackPanel>

            <!-- Titel -->
            <TextBlock Text="➕ Nieuwe order aanmaken"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,0,0,20"/>

            <!-- Klant -->
            <TextBlock Text="Klant *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox x:Name="CustomerBox" Height="34" Margin="0,0,0,12">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} {1}">
                                    <Binding Path="FirstName"/>
                                    <Binding Path="LastName"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Verzendadres -->
            <TextBlock Text="Verzendadres *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="ShippingBox" Height="34" Padding="8,6" FontSize="12"
                     BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,8"
                     TextChanged="ShippingBox_TextChanged"/>

            <!-- Factuuradres -->
            <CheckBox x:Name="SameAsShippingCheck"
                      Content="Zelfde als verzendadres"
                      FontSize="12" Margin="0,0,0,6"
                      Checked="SameAsShipping_Changed"
                      Unchecked="SameAsShipping_Changed"/>
            <TextBlock Text="Factuuradres *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="BillingBox" Height="34" Padding="8,6" FontSize="12"
                     BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,12"/>

            <!-- Betaalmethode -->
            <TextBlock Text="Betaalmethode *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox x:Name="PaymentBox" Height="34" Margin="0,0,0,16"/>

            <!-- Artikelen header + knop -->
            <Grid Margin="0,0,0,6">
                <TextBlock Text="Artikelen *" FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Content="+ Rij toevoegen"
                        HorizontalAlignment="Right"
                        Padding="10,4"
                        Background="#3498DB" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Click="AddItem_Click"/>
            </Grid>

            <!-- Kolomheader artikelen -->
            <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="85"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Product"        FontSize="11" FontWeight="SemiBold" Foreground="#7F8C8D"/>
                <TextBlock Grid.Column="1" Text="Aantal"         FontSize="11" FontWeight="SemiBold" Foreground="#7F8C8D" TextAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Eenheidsprijs"  FontSize="11" FontWeight="SemiBold" Foreground="#7F8C8D" TextAlignment="Right" Margin="0,0,4,0"/>
                <TextBlock Grid.Column="3" Text="Subtotaal"      FontSize="11" FontWeight="SemiBold" Foreground="#7F8C8D" TextAlignment="Right" Margin="0,0,4,0"/>
            </Grid>

            <!-- Scroll-container met artikelrijen -->
            <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8">
                <ScrollViewer MaxHeight="170" VerticalScrollBarVisibility="Auto" Padding="4">
                    <ItemsControl x:Name="ItemsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="85"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Product ComboBox -->
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding Products}"
                                              SelectedItem="{Binding SelectedProduct, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="Name"
                                              Height="28" Margin="0,0,4,0"/>

                                    <!-- Aantal -->
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                             Height="28" Padding="4,4"
                                             TextAlignment="Center"
                                             Margin="0,0,4,0"
                                             BorderBrush="#BDC3C7" BorderThickness="1"/>

                                    <!-- Eenheidsprijs (read-only) -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding UnitPrice, StringFormat=€{0:N2}}"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"
                                               Margin="0,0,8,0"
                                               Foreground="#555"/>

                                    <!-- Subtotaal (read-only) -->
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding LineTotal, StringFormat=€{0:N2}}"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"
                                               Margin="0,0,4,0"
                                               FontWeight="SemiBold"/>

                                    <!-- Verwijder-knop -->
                                    <Button Grid.Column="4"
                                            Content="✕" Height="28" Width="26"
                                            Background="#E74C3C" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            FontSize="10"
                                            Tag="{Binding}"
                                            Click="RemoveItemRow_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Totaalregel -->
            <TextBlock x:Name="TotalText"
                       Text="Totaal: €0,00"
                       FontSize="13" FontWeight="Bold"
                       HorizontalAlignment="Right"
                       Foreground="#2C3E50"
                       Margin="0,0,0,12"/>

            <!-- Validatiefout -->
            <TextBlock x:Name="ErrorText"
                       Foreground="#E74C3C" FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"
                       Visibility="Collapsed"/>

            <!-- Knoppen -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="✓ Opslaan"
                        Width="110" Height="36"
                        Background="#27AE60" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Margin="0,0,8,0" Click="Save_Click"/>
                <Button Content="✕ Annuleren"
                        Width="110" Height="36"
                        Background="#95A5A6" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Click="Cancel_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>